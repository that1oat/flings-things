createCmd("unorbit", "Stop orbiting NPCs", function()
    local count = 0

    -- clear the orbit target
    getgenv().OrbitTarget = nil

    -- stop all NPC orbit loops
    for npc, loop in pairs(getgenv().OrbitLoops) do
        if loop and task.cancel then
            pcall(function()
                task.cancel(loop) -- cancel the loop
            end)
            count += 1
        end

        -- reset humanoid walkspeed
        pcall(function()
            local hum = npc:FindFirstChildOfClass("Humanoid")
            if hum then
                hum.WalkSpeed = 16
            end
        end)
    end

    -- clear the loops table
    getgenv().OrbitLoops = {}

    showNotification("Unorbit", "Stopped " .. tostring(count) .. " NPCs from orbiting")
end)



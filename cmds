createCmd("follow", "Makes all owned NPCs follow the target player quickly", function(args)
    local target = findPlayer(args[1] or "")
    if not target then
        return showNotification("Error", "Player not found")
    end

    local tChar = target.Character
    if not tChar then
        return showNotification("Error", "Target character not found")
    end

    local tHRP = tChar:FindFirstChild("HumanoidRootPart")
    if not tHRP then
        return showNotification("Error", "Target HumanoidRootPart missing")
    end

    -- update global follow target
    getgenv().FollowTarget = target

    local count = 0

    for npc, head in pairs(getgenv().GrabbedNPCs) do
        if not getgenv().FollowLoops[npc] then
            pcall(function()
                if not npc or not npc.Parent then return end

                local hum = npc:FindFirstChildOfClass("Humanoid")
                local hrp = npc:FindFirstChild("HumanoidRootPart") or head
                if not hum or not hrp then return end

                -- make NPC fast
                hum.WalkSpeed = 100

                -- start a persistent loop
                getgenv().FollowLoops[npc] = task.spawn(function()
                    while npc.Parent do
                        local currentTarget = getgenv().FollowTarget
                        if currentTarget and currentTarget.Character then
                            local targetHRP = currentTarget.Character:FindFirstChild("HumanoidRootPart")
                            if targetHRP then
                                hum:MoveTo(targetHRP.Position + Vector3.new(math.random(-3,3),0,math.random(-3,3)))
                            end
                        end
                        task.wait(0.25)
                    end

                    -- cleanup loop when npc is gone
                    getgenv().FollowLoops[npc] = nil
                end)

                count += 1
            end)
        end
    end

    showNotification("Follow", "Making " .. tostring(count) .. " NPCs follow " .. target.Name .. " at speed 40")
end)

--====================================
-- .unfollow Command
--====================================
createCmd("unfollow", "Stops all NPCs from following", function()
    local count = 0

    -- clear the global follow target
    getgenv().FollowTarget = nil

    -- stop all loops
    for npc, loop in pairs(getgenv().FollowLoops) do
        if loop and task.cancel then
            pcall(function()
                task.cancel(loop) -- cancel the loop
            end)
            count += 1
        end

        -- reset humanoid walkspeed if possible
        pcall(function()
            local hum = npc:FindFirstChildOfClass("Humanoid")
            if hum then
                hum.WalkSpeed = 16
            end
        end)
    end

    -- clear loops table
    getgenv().FollowLoops = {}

    showNotification("Unfollow", "Stopped " .. tostring(count) .. " NPCs from following")
end)


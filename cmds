-- Handle toy once
local function handleToy(toy)
    if currentToy and currentToy.Parent then return end
    local soundPart = toy:WaitForChild("SoundPart")
    ReplicatedStorage.GrabEvents.SetNetworkOwner:FireServer(soundPart, soundPart.CFrame)

    local conn
    conn = RunService.Heartbeat:Connect(function()
        local ownerTag = soundPart:FindFirstChild("PartOwner")
        if ownerTag and ownerTag:IsA("StringValue") and ownerTag.Value == LocalPlayer.Name then
            ReplicatedStorage.GrabEvents.DestroyGrabLine:FireServer(soundPart)
            toy:SetAttribute(UNIQUE_ATTRIBUTE, true)
            currentToy = toy
            wait()
            ReplicatedStorage.GrabEvents.SetNetworkOwner:FireServer(soundPart, soundPart.CFrame)

            if not soundPart:FindFirstChildOfClass("BodyGyro") then
                local gyro = Instance.new("BodyGyro")
                gyro.Parent = soundPart
                gyro.MaxTorque = Vector3.new(1e5,1e5,1e5)
                gyro.P = 1e4
                gyro.CFrame = soundPart.CFrame * CFrame.Angles(math.rad(ROTATION_OFFSET.X), math.rad(ROTATION_OFFSET.Y), math.rad(ROTATION_OFFSET.Z))
            end

            for _, part in ipairs(toy:GetDescendants()) do
                if part:IsA("BasePart") then
                    local bv = Instance.new("BodyVelocity")
                    bv.Velocity = Vector3.new(0,0,0)
                    bv.MaxForce = Vector3.new(1e5,1e5,1e5)
                    bv.P = 0
                    bv.Parent = part
                end
            end
            conn:Disconnect()
        end
    end)
end


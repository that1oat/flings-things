createCmd("graball", "Grab all eligible NPCs outside plots", function()
    local myChar = LocalPlayer.Character
    if not myChar then return end

    local myHRP = myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end

    -- save old position
    local oldCF = myHRP.CFrame

    getgenv().GrabbedNPCs = getgenv().GrabbedNPCs or {}
    local GrabbedNPCs = getgenv().GrabbedNPCs

    -- cleanup task
    task.spawn(function()
        game:GetService("RunService").PreRender:Connect(function()
            for model, head in pairs(GrabbedNPCs) do
                local ok, keep = pcall(function()
                    if not head or not head.Parent then
                        return false
                    end

                    local po = head:FindFirstChild("PartOwner")
                    if po and po:IsA("StringValue") and po.Value ~= LocalPlayer.Name then
                        return false
                    end

                    return true
                end)

                if not ok or not keep then
                    GrabbedNPCs[model] = nil
                end
            end
            task.wait()
        end)
    end)

    -- grab loop
    for _, inst in ipairs(workspace:GetDescendants()) do
        if inst:IsA("Model")
        and (
            inst.Name == "YouDecoy"
            or inst.Name == "YouLittle"
            or inst.Name == "Cashier"
            or inst.Name == "Jumpin"
            or inst.Name == "Dummy"
            or inst.Name == "Book"
        ) then

            -- skip if already tracked
            if GrabbedNPCs[inst] then
                continue
            end

            local parentFolder = inst.Parent
            if not parentFolder
               or (not tostring(parentFolder.Name):find("SpawnedInToys")
                   and not tostring(parentFolder.Name):find("Robloxians")) then
                continue
            end

            local head = inst:FindFirstChild("Head")
            local hrp = inst:FindFirstChild("HumanoidRootPart") or head
            if not head or not hrp then
                continue
            end

            -- already owned
            local po = head:FindFirstChild("PartOwner")
            if po and po:IsA("StringValue") and po.Value == LocalPlayer.Name then
                GrabbedNPCs[inst] = head
                continue
            end

            -- attempt ownership (max 4s)
            local start = tick()
            local owned = false

            while tick() - start < 4 do
                myHRP.CFrame = hrp.CFrame
                task.wait(0)

                game.ReplicatedStorage.GrabEvents.SetNetworkOwner:FireServer(
                    head,
                    head.CFrame
                )

                local check = head:FindFirstChild("PartOwner")
                if check and check:IsA("StringValue") and check.Value == LocalPlayer.Name then
                    owned = true
                    break
                end

                task.wait(0.09)
            end

            if owned then
                game.ReplicatedStorage.GrabEvents.DestroyGrabLine:FireServer(head)
                GrabbedNPCs[inst] = head
            end
        end
    end

    -- return to old position
    myHRP.CFrame = oldCF

    local count = 0
    for _ in pairs(GrabbedNPCs) do count += 1 end

    showNotification("GrabAll", "Tracking " .. count .. " NPCs")
end)


            cmdName.TextColor3 = Color3.fromRGB(255, 255, 255)
            cmdName.Font = Enum.Font.GothamBold
            cmdName.TextSize = 16
            cmdName.TextXAlignment = Enum.TextXAlignment.Left
            cmdName.Parent = cmdFrame

            -- Shortcut label

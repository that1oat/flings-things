createCmd("kill", "Sit on blob and kill target", function(args)
    local target = findPlayer(args[1] or "")
    if not target then
        return showNotification("Error", "Player not found")
    end

    local inPlot = target:FindFirstChild("InPlot")
    if inPlot and inPlot.Value == true then
        return showNotification("Blocked", "Player is in plot")
    end

    if not BlobAPI:SitOnBlob() then
        return showNotification("Failed", "Failed to sit on blob")
    end

    local blob = BlobAPI:GetPathOfCurrentBlob()
    if not blob then
        return showNotification("Failed", "Blob path not found")
    end

    local blobScript = blob:WaitForChild("BlobmanSeatAndOwnerScript")

    local start = tick()
    local reached = false

    while tick() - start < 3 do
        local myChar = LocalPlayer.Character
        local tChar = target.Character
        if myChar and tChar then
            local myHRP = myChar:FindFirstChild("HumanoidRootPart")
            local tHRP = tChar:FindFirstChild("HumanoidRootPart")
            if myHRP and tHRP then
                myHRP.CFrame = tHRP.CFrame
                if (myHRP.Position - tHRP.Position).Magnitude <= 35 then
                    reached = true
                    break
                end
            end
        end
        task.wait(0.1)
    end

    if not reached then
        return showNotification("Failed", "Could not reach target")
    end

    local char = target.Character
    if not char then return end

    local hum = char:FindFirstChildOfClass("Humanoid")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp then return end

    local rightDetector = blob:FindFirstChild("RightDetector", true)
    local rightWeld = blob:FindFirstChild("RightWeld", true)
    if not rightDetector or not rightWeld then
        return showNotification("Failed", "Blob grab parts missing")
    end

    task.wait(0.3)

    blobScript.CreatureGrab:FireServer(rightDetector, hrp, rightWeld)

    hum.BreakJointsOnDeath = false
    hum:ChangeState(Enum.HumanoidStateType.Dead)
    hum.Died:Wait()

    for _, p in ipairs(char:GetDescendants()) do
        if p:IsA("BasePart") then
            blobScript.CreatureRelease:FireServer(rightWeld, p)
            task.wait(0.01)
        end
    end

    showNotification("Success", target.Name .. " successfully died")
end)


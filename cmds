-- .orbit Command (BodyPosition + dynamic spacing)
--====================================
createCmd("orbit", "Make NPCs orbit around a player with spacing using BodyPosition", function(args)
    local playerName = args[1]
    if not playerName then
        return showNotification("Error", "Specify a player")
    end

    local target = findPlayer(playerName)
    if not target then
        return showNotification("Error", "Player not found")
    end

    local tChar = target.Character
    if not tChar then
        return showNotification("Error", "Target character not found")
    end

    local tHRP = tChar:FindFirstChild("HumanoidRootPart")
    if not tHRP then
        return showNotification("Error", "Target HumanoidRootPart missing")
    end

    local radius = 6
    local orbitSpeed = 2       -- radians per second
    local updateRate = 0.05

    getgenv().OrbitTarget = target
    getgenv().OrbitLoops = getgenv().OrbitLoops or {}

    -- get NPCs dynamically from grabbed NPCs
    local function getNPCs()
        local list = {}
        for npc, head in pairs(getgenv().GrabbedNPCs) do
            if npc and npc.Parent then
                table.insert(list, {npc=npc, head=head})
            end
        end
        return list
    end

    -- create BodyPosition for NPC
    local function addBodyPos(npc)
        local hrp = npc:FindFirstChild("HumanoidRootPart") or npc:FindFirstChild("Head")
        if not hrp then return nil end

        local bp = hrp:FindFirstChild("OrbitBP")
        if not bp then
            bp = Instance.new("BodyPosition")
            bp.Name = "OrbitBP"
            bp.MaxForce = Vector3.new(1e5,1e5,1e5)
            bp.P = 5000
            bp.D = 100
            bp.Position = hrp.Position
            bp.Parent = hrp
        end
        return bp
    end

    if getgenv().OrbitLoops["mainLoop"] then return end -- avoid duplicate loop

    getgenv().OrbitLoops["mainLoop"] = task.spawn(function()
        local angleOffsets = {}
        local t = 0
        while getgenv().OrbitTarget and getgenv().OrbitTarget.Character and getgenv().OrbitTarget.Character:FindFirstChild("HumanoidRootPart") do
            local npcs = getNPCs()
            local total = #npcs
            if total == 0 then break end

            -- recalc angle offsets evenly spaced
            for i, data in ipairs(npcs) do
                angleOffsets[i] = ((i-1)/total) * (2*math.pi)
            end

            -- update positions
            for i, data in ipairs(npcs) do
                local npc = data.npc
                local bp = addBodyPos(npc)
                if bp then
                    local angle = angleOffsets[i] + t * orbitSpeed
                    local offset = Vector3.new(math.cos(angle) * radius, 0, math.sin(angle) * radius)
                    bp.Position = getgenv().OrbitTarget.Character.HumanoidRootPart.Position + offset
                end
            end

            t = t + updateRate
            task.wait(updateRate)
        end

        -- cleanup
        for _, data in ipairs(getNPCs()) do
            local hrp = data.npc:FindFirstChild("HumanoidRootPart") or data.npc:FindFirstChild("Head")
            if hrp then
                local bp = hrp:FindFirstChild("OrbitBP")
                if bp then bp:Destroy() end
            end
        end
        getgenv().OrbitLoops["mainLoop"] = nil
    end)

    showNotification("Orbit", "Orbiting NPCs around " .. target.Name)
end)


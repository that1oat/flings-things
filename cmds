local Commands = {}

--====================================
-- createCmd with smart shortcuts
--====================================
local function createCmd(name, desc, callback)
    name = name:lower()

    -- Add main command
    Commands[name] = {
        Desc = desc,
        Run = callback,
        Shortcut = nil
    }

    -- Generate a sensible shortcut
    -- Rule: first letter + last character if it's a number
    local shortcut = name:sub(1,1)
    local lastChar = name:sub(-1)
    if tonumber(lastChar) then
        shortcut = shortcut .. lastChar
    end

    -- Only create shortcut if it's not already used
    if not Commands[shortcut] then
        Commands[shortcut] = {
            Desc = "[Shortcut] " .. desc,
            Run = callback,
            Shortcut = nil
        }
        -- Save shortcut info in main command
        Commands[name].Shortcut = shortcut
    else
        -- Optional: if first letter is taken, try first 2 letters + number if exists
        local altShortcut = name:sub(1,2)
        if tonumber(lastChar) then
            altShortcut = altShortcut .. lastChar
        end
        if not Commands[altShortcut] then
            Commands[altShortcut] = {
                Desc = "[Shortcut] " .. desc,
                Run = callback,
                Shortcut = nil
            }
            Commands[name].Shortcut = altShortcut
        end
    end
end

local function findPlayer(name)
    name = name:lower()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr.Name:lower():sub(1, #name) == name
        or plr.DisplayName:lower():sub(1, #name) == name then
            return plr
        end
    end
end


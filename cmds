-- Spawn toy
local function spawnToy()
    local baseCFrame = getSpawnCFrame()
    

-- Spawn arguments
local spawnArgs = {
    TOY_NAME,
    baseCFrame * CFrame.Angles(-0.705049991607666, 0.4947306513786316, 0.38397595286369324),
    Vector3.new(0, 35.3129997253418, 0)
}

    -- invoke spawn
    task.spawn(function()
    ReplicatedStorage.MenuToys.SpawnToyRemoteFunction:InvokeServer(unpack(spawnArgs))
    end)

    -- wait for the toy instance in your folder
    local toyFolder = workspace:WaitForChild(LocalPlayer.Name .. "SpawnedInToys")
    local toy
    repeat
        toy = toyFolder:FindFirstChild(TOY_NAME)
        task.wait(0.1)
    until toy

    return toy

createCmd("unseat", "Unseat a player using blob and restore positions", function(args)
    local target = findPlayer(args[1] or "")
    if not target then
        return showNotification("Error", "Player not found")
    end

    local tChar = target.Character
    local myChar = LocalPlayer.Character
    if not tChar or not myChar then return end

    local tHum = tChar:FindFirstChildOfClass("Humanoid")
    local tHRP = tChar:FindFirstChild("HumanoidRootPart")
    local myHRP = myChar:FindFirstChild("HumanoidRootPart")
    if not tHum or not tHRP or not myHRP then return end

    -- Check if seated using Humanoid.SeatPart
    if not tHum.SeatPart then
        return showNotification("Error", target.Name .. " is not seated")
    end

    local oldMyCF = myHRP.CFrame
    local oldTargetCF = tHRP.CFrame

    -- Sit on blob
    if not BlobAPI:SitOnBlob() then
        return showNotification("Failed", "Could not sit on blob")
    end

    local blob = BlobAPI:GetPathOfCurrentBlob()
    if not blob then return showNotification("Failed", "Blob path not found") end

    local blobScript = blob:WaitForChild("BlobmanSeatAndOwnerScript")
    local rightDetector = blob:FindFirstChild("RightDetector", true)
    local rightWeld = blob:FindFirstChild("RightWeld", true)
    if not rightDetector or not rightWeld then
        return showNotification("Failed", "Blob grab parts missing")
    end

    -- Teleport to target
    myHRP.CFrame = tHRP.CFrame + Vector3.new(0, 2, 0)
    task.wait(0.2)

    -- Grab target
    blobScript.CreatureGrab:FireServer(rightDetector, tHRP, rightWeld)
    task.wait(0.15)

    -- Release immediately
    blobScript.CreatureRelease:FireServer(rightWeld, tHRP)
    task.wait(0.1)

    -- Teleport both back
    myHRP.CFrame = oldMyCF
    tHRP.CFrame = oldMyCF
    task.wait(0.1)

    -- Force network ownership so physics resets properly
    game.ReplicatedStorage.GrabEvents.SetNetworkOwner:FireServer(tHRP, tHRP.CFrame)
    game.ReplicatedStorage.GrabEvents.DestroyGrabLine:FireServer(tHRP)

    showNotification("Success", target.Name .. " has been unseated")
end)


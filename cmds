            cmdShortcut.Text = shortcutText
            cmdShortcut.TextColor3 = Color3.fromRGB(180, 180, 180)
            cmdShortcut.Font = Enum.Font.Gotham
            cmdShortcut.TextSize = 14
            cmdShortcut.TextXAlignment = Enum.TextXAlignment.Left
